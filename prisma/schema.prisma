generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
}

model LogEntry {
  id            String   @id @db.VarChar(36)
  taskType      String   @map("task_type") @db.VarChar(20)
  ticketKey     String   @default("") @map("ticket_key") @db.VarChar(50)
  title         String   @default("") @db.VarChar(500)
  hours         Int      @default(0)
  minutes       Int      @default(0)
  timeSpent     Decimal  @default(0) @map("time_spent") @db.Decimal(8, 4)
  date          DateTime @db.Date
  teamworkType  String?  @map("teamwork_type") @db.VarChar(20)
  takeoffPeriod String?  @map("takeoff_period") @db.VarChar(20)
  createdAt     BigInt   @map("created_at")

  @@map("log_entries")
}

model JiraTask {
  ticketKey String @id @map("ticket_key") @db.VarChar(50)
  title     String @default("") @db.VarChar(500)

  @@map("jira_tasks")
}

model TeamworkTask {
  id           Int    @id @default(autoincrement())
  teamworkType String @map("teamwork_type") @db.VarChar(20)
  name         String @db.VarChar(500)

  @@unique([teamworkType, name], name: "uq_type_name")
  @@map("teamwork_tasks")
}

model Invoice {
  id          String        @id @db.VarChar(36)
  invoiceType String        @default("invoice") @map("invoice_type") @db.VarChar(20)
  domain      String        @default("") @db.VarChar(255)
  total       Decimal       @default(0) @db.Decimal(15, 2)
  datetime    DateTime      @db.Date
  description String?       @db.Text
  status      String        @default("pending") @db.VarChar(20)
  createdAt   BigInt        @map("created_at")
  items       InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   String  @map("invoice_id") @db.VarChar(36)
  description String  @db.Text
  price       Decimal @default(0) @db.Decimal(15, 2)
  quantity    Decimal @default(1) @db.Decimal(10, 4)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Bill {
  id        String   @id @db.VarChar(36)
  billType  String   @map("bill_type") @db.VarChar(20)
  location  String   @db.VarChar(20)
  name      String?  @db.VarChar(100)
  amount    Decimal  @db.Decimal(15, 2)
  billMonth String   @map("bill_month") @db.VarChar(7)  // YYYY-MM
  paidDate  DateTime @map("paid_date") @db.Date
  note      String?  @db.Text
  createdAt BigInt   @map("created_at")

  @@index([billMonth])
  @@index([location])
  @@index([name])
  @@map("bills")
}

model BillName {
  id        String @id @db.VarChar(36)
  name      String @unique @db.VarChar(100)
  createdAt BigInt @map("created_at")

  @@map("bill_names")
}

model PersonalEvent {
  id          String  @id @db.VarChar(36)
  title       String  @db.VarChar(255)
  date        String  @db.VarChar(10)    // YYYY-MM-DD
  time        String? @db.VarChar(5)     // HH:MM (optional)
  eventType   String  @db.VarChar(50)    @map("event_type")
  description String? @db.Text
  reminder    String  @default("none")   @db.VarChar(20)  // none | on_day | 1_day | 3_days | 1_week | on_miss
  completed   Boolean @default(false)
  createdAt   BigInt  @map("created_at")

  @@index([date])
  @@map("personal_events")
}

model EventType {
  id        String @id @db.VarChar(36)
  name      String @unique @db.VarChar(50)
  color     String @db.VarChar(20)
  createdAt BigInt @map("created_at")

  @@map("event_types")
}

model CycleEntry {
  id        String  @id @db.VarChar(36)
  date      String  @unique @db.VarChar(10)  // YYYY-MM-DD
  bleeding  String  @default("none") @db.VarChar(20)  // none | spotting | light | medium | heavy
  mucus     String  @default("none") @db.VarChar(20)  // none | sticky | creamy | watery | egg_white
  sensation String  @default("dry")  @db.VarChar(20)  // dry | moist | wet | slippery
  isPeakDay Boolean @default(false)  @map("is_peak_day")
  note      String? @db.Text
  createdAt BigInt  @map("created_at")

  @@index([date])
  @@map("cycle_entries")
}
